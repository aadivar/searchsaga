{
  "version": "1.0.0",
  "project": {
    "name": "SearchSaga",
    "description": "Connecting the Dots — a search experience for curious minds",
    "stack": ["Next.js", "TypeScript"]
  },
  "agents": {
    "model": "haiku",
    "specs": { "enabled": true },
    "prd": { "enabled": true },
    "security": { "enabled": true },
    "memory": { "enabled": true },
    "custom": []
  },
  "docs": {
    "path": "docs",
    "progressFile": "PROGRESS.md",
    "prdFile": "PRD.md",
    "specsFile": "SPECS.md",
    "securityFile": "SECURITY.md",
    "featuresDir": "features"
  },
  "orchestration": {
    "readProgressOnStart": true,
    "launchAgentsAfterTask": true,
    "triggerMethod": "hooks+claude.md",
    "maxParallelAgents": 3
  }
}